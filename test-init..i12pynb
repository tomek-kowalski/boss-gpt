   ],
   "source": [
    "\n",
    "# Device\n",
    "device = torch.device('cuda:0' if torch.cuda.is_available() else 'cpu')\n",
    "timg = timg_gray.to(device)\n",
    "\n",
    "print(\"timg1 shape:\", timg1.shape)  # Must be (1,1,H,W)\n",
    "print(\"timg2 shape:\", timg2.shape)  # Must be (1,1,H,W)\n",
    "\n",
    "# Patch size\n",
    "PS = 41\n",
    "\n",
    "descriptor = SIFTDescriptor(PS, rootsift=True).to(device)\n",
    "resp = BlobDoG()\n",
    "scale_pyr = ScalePyramid(3, 1.6, PS, double_image=False)\n",
    "nms = ConvQuadInterp3d(10)\n",
    "\n",
    "detector = ScaleSpaceDetector(\n",
    "    num_features=4000,\n",
    "    resp_module=resp,\n",
    "    scale_space_response=True,\n",
    "    nms_module=nms,\n",
    "    scale_pyr_module=scale_pyr,\n",
    "    ori_module=LAFOrienter(32, angle_detector=OriNet(True)),\n",
    "    mr_size=6.0,\n",
    "    minima_are_also_good=True\n",
    ").to(device)\n",
    "\n",
    "\n",
    "with torch.no_grad():\n",
    "\n",
    "    lafs, resps = detector(timg)\n",
    "\n",
    "# -----------------------------\n",
    "# Extract color patches\n",
    "# -----------------------------\n",
    "patches = extract_patches_from_pyramid(timg, lafs, PS).contiguous()\n",
    "B, N, CH, H, W = patches.shape\n",
    "\n",
    "patches_flat = patches.view(B*N, CH, H, W)\n",
    "\n",
    "descs_flat = descriptor(patches_flat)\n",
    "\n",
    "descs = descs_flat.view(B, N, -1)\n",
    "\n",
    "scores, matches = match_snn(descs[0], descs[1], 0.9)\n",
    "\n",
    "# -----------------------------\n",
    "# RANSAC homography\n",
    "# -----------------------------\n",
    "src_pts = lafs[0,matches[:,0], :, 2].cpu().numpy()\n",
    "dst_pts = lafs[1,matches[:,1], :, 2].cpu().numpy()\n",
    "H, mask = cv2.findHomography(src_pts, dst_pts, cv2.RANSAC, 1.0, 0.999, 10000)\n",
    "inliers = matches[torch.from_numpy(mask).bool().squeeze(), :]\n",
    "\n",
    "# -----------------------------\n",
    "# Visualize results\n",
    "# -----------------------------\n",
    "for i in range(2):\n",
    "    visualize_LAF(timg, lafs[:,inliers[:,i]], i)\n",
    "\n",
    "print(f\"Total matches: {len(matches)}, Inliers: {len(inliers)}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 13,
   "id": "f0cbda3e",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Saved missing keypoints report to: E:\\boss-gpt\\reports\\missing_keypoints_report.csv\n",
      "Saved diff visualization to: E:\\boss-gpt\\reports\\diff_missing.png\n"
     ]
    }
   ],
   "source": [
    "all_idx1 = np.arange(lafs.shape[1])\n",
    "all_idx2 = np.arange(lafs.shape[1])\n",
    "\n",
    "# Matched indices that are inliers\n",
    "inliers_idx1 = inliers[:,0].cpu().numpy()\n",
    "inliers_idx2 = inliers[:,1].cpu().numpy()\n",
    "\n",
    "# Missing points = not inliers\n",
    "missing_idx1 = np.setdiff1d(all_idx1, inliers_idx1)\n",
    "missing_idx2 = np.setdiff1d(all_idx2, inliers_idx2)\n",
    "\n",
    "# -----------------------------\n",
    "# Paths\n",
    "# -----------------------------\n",
    "final_report_path = os.path.join(reports, \"missing_keypoints_report.csv\")\n",
    "diff_png_path    = os.path.join(reports, \"diff_missing.png\")\n",
    "\n",
    "# -----------------------------\n",
    "# Prepare missing keypoints coordinates\n",
    "# -----------------------------\n",
    "coords_img1 = [lafs[0, idx, :, 2].cpu().numpy() for idx in missing_idx1]\n",
    "coords_img2 = [lafs[1, idx, :, 2].cpu().numpy() for idx in missing_idx2]\n",
    "\n",
    "# Create DataFrames\n",
    "df_missing_img1 = pd.DataFrame(coords_img1, columns=['x','y'])\n",
    "df_missing_img1['image'] = 'image_1_only'\n",
    "\n",
    "df_missing_img2 = pd.DataFrame(coords_img2, columns=['x','y'])\n",
    "df_missing_img2['image'] = 'image_2_only'\n",
    "\n",
    "# Combine all missing points\n",
    "df_missing = pd.concat([df_missing_img1, df_missing_img2], ignore_index=True)\n",
    "\n",
    "# Save CSV\n",
    "df_missing.to_csv(final_report_path, index=False)\n",
    "print(f\"Saved missing keypoints report to: {final_report_path}\")\n",
    "\n",
    "# -----------------------------\n",
    "# Create diff image\n",
    "# -----------------------------\n",
    "# Convert tensors to images\n",
    "img1_np = (timg1.cpu().numpy() * 255).astype(np.uint8).transpose(1,2,0)\n",
    "img2_np = (timg2.cpu().numpy() * 255).astype(np.uint8).transpose(1,2,0)\n",
    "\n",
    "# Ensure 3 channels\n",
    "if img1_np.shape[2] == 1: img1_np = cv2.cvtColor(img1_np, cv2.COLOR_GRAY2RGB)\n",
    "if img2_np.shape[2] == 1: img2_np = cv2.cvtColor(img2_np, cv2.COLOR_GRAY2RGB)\n",
    "\n",
    "img1_np = np.ascontiguousarray(img1_np)\n",
    "img2_np = np.ascontiguousarray(img2_np)\n",
    "\n",
    "# Draw missing points in red\n",
    "for _, row in df_missing_img1.iterrows():\n",
    "    cv2.circle(img1_np, (int(row['x']), int(row['y'])), 4, (255,0,0), -1)\n",
    "\n",
    "for _, row in df_missing_img2.iterrows():\n",
    "    cv2.circle(img2_np, (int(row['x']), int(row['y'])), 4, (255,0,0), -1)\n",
    "\n",
    "# Combine side by side\n",
    "diff_img = np.hstack([img1_np, img2_np])\n",
    "\n",
    "# Save PNG\n",
    "cv2.imwrite(diff_png_path, cv2.cvtColor(diff_img, cv2.COLOR_RGB2BGR))\n",
    "print(f\"Saved diff visualization to: {diff_png_path}\")"
   ]
  }
 ],
